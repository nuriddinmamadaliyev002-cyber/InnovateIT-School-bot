# ════════════════════════════════════════════════════════════
# InnovateIT School Bot - Environment Configuration
# ════════════════════════════════════════════════════════════
#
# MUHIM: Bu faylni .env ga nusxalang va o'z qiymatlaringizni kiriting!
# cp .env.example .env
#
# ════════════════════════════════════════════════════════════

# ── Telegram Bot Token ──────────────────────────────────────
# @BotFather dan olingan token
BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz1234567890

# ── Admin ID'lar ────────────────────────────────────────────
# Super admin'larning Telegram ID raqamlari (vergul bilan ajratilgan)
# ID'ni olish: @userinfobot dan
ADMIN_IDS=123456789,987654321

# ── Proxy (agar kerak bo'lsa) ──────────────────────────────
# Agar Telegram bloklangan bo'lsa, SOCKS5 proxy ishlatish mumkin
# Format: socks5://username:password@host:port
# Yoki bo'sh qoldiring
PROXY_URL=

# ════════════════════════════════════════════════════════════
# Qo'shimcha sozlamalar (ixtiyoriy)
# ════════════════════════════════════════════════════════════

# Database fayl yo'li (standart: school.db)
# DATABASE_PATH=school.db

# Log level (DEBUG, INFO, WARNING, ERROR)
# LOG_LEVEL=INFO

# Webhook mode uchun (agar ishlatilsa)
# WEBHOOK_URL=https://your-domain.com
# WEBHOOK_PORT=8443
